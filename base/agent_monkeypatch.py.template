class %%CLASS_NAME%%(BaseAgent):
    """Harbor agent que usa os prompts reais do projeto via import."""

    @staticmethod
    def name() -> str:
        return "%%AGENT_NAME%%"

    def version(self):
        return "%%AGENT_VERSION%%"

    async def setup(self, environment: BaseEnvironment) -> None:
        await environment.exec("mkdir -p /logs/agent")

    async def run(
        self, instruction: str, environment: BaseEnvironment, context: AgentContext
    ) -> None:
        try:
            data = json.loads(instruction)
        except json.JSONDecodeError:
            data = {"topic": instruction}

        role = data.get("role", "generic")
        config = ROLE_CONFIG.get(role, {"model": "sonnet", "timeout": 120})

        if role == "generic":
            output = _run_claude(instruction, config["model"], config["timeout"])
        else:
            prompt, model = await _build_prompt_via_monkey_patch(role, data)
            if prompt is None:
                raise RuntimeError(f"Falha ao capturar prompt para role={role}")

            raw = _run_claude(prompt, model or config["model"], config["timeout"])

            # Extrair JSON para roles que retornam JSON
            if data.get("json_output", False):
                output = _extract_json(raw)
            else:
                output = raw

        with tempfile.NamedTemporaryFile(mode="w", suffix=".txt", delete=False) as f:
            f.write(output)
            tmp_path = f.name
        await environment.upload_file(tmp_path, "/logs/agent/output.txt")
        os.unlink(tmp_path)
        context.metadata = {"output_length": len(output), "role": role}
