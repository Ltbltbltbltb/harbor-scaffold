def _run_claude(prompt: str, model: str = "sonnet", timeout: int = 120) -> str:
    """Chama claude -p com --output-format text (como o projeto real)."""
    claude_cmd = os.environ.get("CLAUDE_CLI_PATH") or "claude"
    for attempt in range(3):
        try:
            result = subprocess.run(
                [
                    claude_cmd,
                    "-p",
                    prompt,
                    "--output-format",
                    "text",
                    "--max-turns",
                    "1",
                    "--tools",
                    "",
                    "--model",
                    model,
                ],
                capture_output=True,
                text=True,
                timeout=timeout,
            )
            if result.returncode != 0:
                err = result.stderr.strip() or result.stdout.strip()
                if "429" in err or "rate" in err.lower():
                    if attempt < 2:
                        time.sleep(30 * (attempt + 1))
                        continue
                raise RuntimeError(f"claude -p falhou: {err[:300]}")
            return result.stdout.strip()
        except subprocess.TimeoutExpired:
            if attempt < 2:
                time.sleep(10)
                continue
            raise RuntimeError(f"timeout {timeout}s")
    raise RuntimeError("max retries")


def _extract_json(text: str) -> str:
    """Extrai JSON de texto livre."""
    start = text.find("{")
    end = text.rfind("}") + 1
    if start >= 0 and end > start:
        return text[start:end]
    return text


async def _build_prompt_via_monkey_patch(role: str, data: dict) -> tuple[str, str]:
    """Importa a funcao real do projeto e captura o prompt que ela construiria.

    Retorna (prompt_capturado, model_usado).
    Usa monkey-patch na funcao LLM para interceptar sem chamar o LLM real.

    TODO: Implemente o dispatch para cada role do seu projeto.
    Use um modulo real do projeto como referencia:

    1. Importe o modulo que contem a funcao LLM
    2. Substitua a funcao por uma fake que captura o prompt
    3. Chame a funcao de entrada do projeto com os dados da task
    4. Restaure a funcao original no finally

    Exemplo:
        import meu_modulo.core as core_mod
        original = core_mod.%%LLM_FUNCTION%%

        async def fake_llm(prompt, **kwargs):
            captured["prompt"] = prompt
            captured["model"] = kwargs.get("model", "sonnet")
            return '{"placeholder": true}'

        core_mod.%%LLM_FUNCTION%% = fake_llm
        try:
            await core_mod.process(input_text=data["input_text"])
        finally:
            core_mod.%%LLM_FUNCTION%% = original
    """
    captured = {"prompt": None, "model": None}

    # TODO: Implementar dispatch por role
    # if role == "meu_role":
    #     ...
    raise NotImplementedError(
        f"Dispatch para role '{role}' nao implementado. "
        "Edite _build_prompt_via_monkey_patch() no agent.py."
    )

    return captured["prompt"], captured["model"]


