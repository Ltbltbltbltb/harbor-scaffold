# harbor-scaffold manifest — configuracao unica por projeto
# Preencha os campos marcados com TODO

project:
  name: "{{PROJECT_SLUG}}"
  path: "{{PROJECT_PATH}}"
  description: "TODO: descricao curta do projeto"

agent:
  strategy: "{{STRATEGY}}"  # direct | monkeypatch | context_inject
  class_name: "{{CLASS_NAME}}"
  agent_name: "{{AGENT_NAME}}"
  version: "0.1.0"
  model: "claude-sonnet-4-6"
  timeout: 300
  max_retries: 3

  # LLM backend: cli | api | openai_compat
  # cli: usa `claude -p` como subprocesso
  # api: usa Anthropic Python SDK
  # openai_compat: usa endpoint compativel com OpenAI
  backend: "cli"
  # api_key_env: "ANTHROPIC_API_KEY"       # para backend: api
  # base_url: "https://api.openai.com/v1"  # para backend: openai_compat
  # api_key_env: "OPENAI_API_KEY"          # para backend: openai_compat

  # System prompt (usado por direct e context_inject; monkeypatch usa prompt do projeto)
  system_prompt: |
    TODO: escreva o system prompt base para o agente.
    Este eh o principal ponto de otimizacao do meta-agente.

  # === Configuracao para estrategia monkeypatch ===
  # Descomente e preencha se strategy = monkeypatch
  #
  # monkeypatch:
  #   project_modules_path: "src"     # path relativo ao project.path, adicionado ao sys.path
  #   llm_function: "_ask_claude"     # nome da funcao LLM a interceptar
  #   roles:
  #     - name: "default"
  #       module: "meu_modulo.core"       # modulo que contem a funcao de entrada
  #       entry_function: "process"       # funcao que chama o LLM internamente
  #       entry_kwargs: ["input_text"]    # kwargs esperados pela entry_function
  #       model: "sonnet"                 # modelo que o bot usa para este role
  #       timeout: 120
  #       json_output: false              # se o output esperado eh JSON
  #       stub_response: ""               # resposta fake para o monkey-patch nao crashar

  # === Configuracao para estrategia context_inject ===
  # Descomente e preencha se strategy = context_inject
  #
  # context_inject:
  #   context_files:                  # arquivos do projeto cujo conteudo sera injetado no prompt
  #     - "CLAUDE.md"
  #     - "src/config.py"
  #   inline_context: |
  #     TODO: contexto adicional sobre o projeto (stack, convencoes, etc.)

benchmark:
  dockerfile_preset: "minimal"  # minimal | jq | custom
  # custom_packages: ["nodejs", "curl"]  # so para preset custom

# === Memory loop opcional (wiki estilo Karpathy + wiki-recall) ===
# Quando habilitado, o benchmark deixa de ser apenas um conjunto fixo de tasks:
# o projeto pode compilar conhecimento em uma wiki local, reutilizar essa wiki
# como contexto e transformar paginas da wiki em novas tasks pareadas
# `no-wiki` vs `with-wiki`. Isso fecha um ciclo de melhoria continua em cima
# do benchmark principal.
memory:
  enabled: false
  wiki_dir: "wiki"
  language: "pt-BR"
  selector_model: "claude-sonnet-4-6"
  writer_model: "claude-sonnet-4-6"
  max_context_chars: 4000
  sync_wiki_recall: true
  min_page_chars: 500
  max_pairs_per_page: 2

  # Optional: gera apenas o protocolo/stub.
  # Voce precisa adaptar a extracao real do runtime do projeto.
  # A intencao e manter o core portatil e deixar explicito o ponto de costura
  # com o runtime especifico de cada aplicacao.
  runtime_adapter:
    enabled: false
    export_script: "scripts/export_runtime_events.py"
